# Optional browser-visible BFF origin. Leave empty to use same-origin /api/*.
NEXT_PUBLIC_BFF_URL=

# Server-side BFF origin for SSR and API proxy routes when mocks are off.
BFF_URL_INTERNAL=http://localhost:8080

# When "1", the frontend targets its own /api/* route handlers (in-memory mocks).
# Flip to empty/0 once the real BFF is running.
NEXT_PUBLIC_USE_MOCKS=1

# Server-only secret used to sign mock session cookies in dev. Not used in prod.
MOCK_SESSION_SECRET=dev-only-not-secret
